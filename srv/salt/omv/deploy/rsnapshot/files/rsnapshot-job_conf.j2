{%- set t = '\t' %}
{%- set src_sf = job.src.sharedfolderref %}
{%- set dst_sf = job.dest.sharedfolderref %}
{%- set src_path = salt['omv_conf.get_sharedfolder_path'](src_sf) if src_sf else '' %}
{%- set dst_path = salt['omv_conf.get_sharedfolder_path'](dst_sf) if dst_sf else '' %}
{%- set mountpoint = '' %}
{%- if src_sf %}
{%- set mountpoint = src_sf
  | omv_conf_get_by_identifier('conf.system.sharedfolder')
  | attr('mntentref')
  | omv_conf_get_by_identifier('conf.system.filesystem.mountpoint')
  | attr('dir')
-%}
{%- endif %}
{%- set src_reldir = '' %}
{%- if mountpoint and src_path.startswith(mountpoint + '/') %}
{%- set src_reldir = src_path[(mountpoint|length + 1):] %}
{%- endif %}
{%- set sourcelabel = mountpoint.lstrip('/') if mountpoint else 'source' %}
{%- if mountpoint %}
{%- set lsblk = salt['cmd.run']("lsblk -o MOUNTPOINT,LABEL -n 2>/dev/null | awk '$1==\"%s\"{print $2; exit}'" % mountpoint, python_shell=True).strip() %}
{%- if lsblk %}
{%- set sourcelabel = lsblk %}
{%- endif %}
{%- endif -%}
# This configuration file is auto-generated.
# WARNING: Do not edit this file, your changes will be lost.
config_version{{ t }}1.2
snapshot_root{{ t }}{{ dst_path }}/{{ sourcelabel }}{% if src_reldir %}/{{ src_reldir }}{% endif %}/
no_create_root{{ t }}1	# target root will be created before rsnapshot is running
{%- if job.hourly|int > 0 %}
retain{{ t }}hourly{{ t }}{{ job.hourly }}
{%- endif %}
{%- if job.daily|int > 0 %}
retain{{ t }}daily{{ t }}{{ job.daily }}
{%- endif %}
{%- if job.weekly|int > 0 %}
retain{{ t }}weekly{{ t }}{{ job.weekly }}
{%- endif %}
{%- if job.monthly|int > 0 %}
retain{{ t }}monthly{{ t }}{{ job.monthly }}
{%- endif %}
{%- if job.yearly|int > 0 %}
retain{{ t }}yearly{{ t }}{{ job.yearly }}
{%- endif %}
{%- if (job.erroroutputonly|int) == 1 %}
verbose{{ t }}{{ t }}{{ verbose_lo }}
{%- else %}
verbose{{ t }}{{ t }}{{ verbose_hi }}
{%- endif %}
loglevel{{ t }}{{ log_level }}
cmd_cp{{ t }}/bin/cp
cmd_rm{{ t }}{{ t }}/bin/rm
{%- if job.cmd_preexec|length > 0 %}
cmd_preexec{{ t }}{{ t }}{{ job.cmd_preexec }}
{%- endif %}
{%- if job.cmd_postexec|length > 0 %}
cmd_postexec{{ t }}{{ t }}{{ job.cmd_postexec }}
{%- endif %}
cmd_rsync{{ t }}/usr/bin/rsync
cmd_logger{{ t }}/usr/bin/logger
logfile{{ t }}{{ t }}{{ logfile }}
rsync_long_args{{ t }}{% if job.rsyncargs|length > 0 %}{{ job.rsyncargs }}{% else %}--delete --numeric-ids --delete-excluded{% endif %}
one_fs{{ t }}{{ job.onefs | int }}
# no extra destination dir
backup{{ t }}{{ src_path }}{{ t }}./
rsync_numtries{{ t }}{{ job.numtries }}
lockfile{{ t }}/var/run/rsnapshot-{{ uuid }}.pid
