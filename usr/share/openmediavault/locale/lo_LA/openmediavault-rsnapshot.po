msgid "Comment"
msgstr "ຄຳອະທິບາຍ"

msgid "Create"
msgstr "ສ້າງ"

msgid "Created job."
msgstr "ສ້າງວຽກແລ້ວ."

msgid "Date & Time"
msgstr "ວັນທີ ແລະ ເວລາ"

msgid "Edit"
msgstr "ແກ້ໄຂ"

msgid "Enable"
msgstr "ເປີດໃຊ້ງານ"

msgid "Enabled"
msgstr "ເປີດໃຊ້ງານແລ້ວ"

msgid "Error output only"
msgstr "ສະແດງສະເພາະຂໍ້ຜິດພາດ"

msgid "Execute backup job ..."
msgstr "ດຳເນີນການວຽກສຳຮອງຂໍ້ມູນ ..."

msgid "Group"
msgstr "ກຸ່ມ"

msgid ""
"If this is enabled, rsync won't span filesystem partitions within a backup "
"point."
msgstr "ຖ້າເປີດໃຊ້ງານສິ່ງນີ້, rsync ຈະບໍ່ຂ້າມພາທິຊັນຂອງລະບົບໄຟລ໌ພາຍໃນຈຸດສຳຮອງ."

msgid "Message"
msgstr "ຂໍ້ຄວາມ"

msgid "One filesystem only"
msgstr "ລະບົບໄຟລ໌ດຽວເທົ່ານັ້ນ"

msgid "Post-exec command"
msgstr "ຄຳສັ່ງຫຼັງການເຮັດວຽກ"

msgid "Pre-exec command"
msgstr "ຄຳສັ່ງກ່ອນການເຮັດວຽກ"

msgid "Retain daily"
msgstr "ເກັບຮັກສາໄວ້ລາຍວັນ"

msgid "Retain hourly"
msgstr "ເກັບຮັກສາໄວ້ລາຍຊົ່ວໂມງ"

msgid "Retain monthly"
msgstr "ເກັບຮັກສາໄວ້ລາຍເດືອນ"

msgid "Retain weekly"
msgstr "ເກັບຮັກສາໄວ້ລາຍອາທິດ"

msgid "Retain yearly"
msgstr "ເກັບຮັກສາໄວ້ລາຍປີ"

msgid "Rsnapshot"
msgstr "Rsnapshot"

msgid "Rsync long arguments"
msgstr "ອາຄິວເມັ້ນແບບຍາວຂອງ Rsync"

msgid "Rsync tries"
msgstr "ຈຳນວນຄັ້ງທີ່ Rsync ພະຍາຍາມ"

msgid "Run"
msgstr "ເລີ່ມເຮັດວຽກ"

msgid "Select a group ..."
msgstr "ເລືອກກຸ່ມ ..."

msgid "Source"
msgstr "ຕົ້ນທາງ"

msgid "Source folder"
msgstr "ໂຟນເດີຕົ້ນທາງ"

msgid "Target"
msgstr "ປາຍທາງ"

msgid "Target folder"
msgstr "ໂຟນເດີປາຍທາງ"

msgid ""
"The Folder used as target for backups. Backups will go into a sub-folder "
"<em>localhost/&lt;label of source filesystem&gt;/&lt;source folder relative "
"path&gt;</em>"
msgstr "ໂຟນເດີທີ່ໃຊ້ເປັນປາຍທາງສຳລັບການສຳຮອງຂໍ້ມູນ. ຂໍ້ມູນທີ່ສຳຮອງຈະຖືກເກັບໄວ້ໃນໂຟນເດີຍ່ອຍ <em>localhost/&lt;label of source filesystem&gt;/&lt;source folder relative path&gt;</em>"

msgid "The shared folder to backup."
msgstr "ໂຟນເດີທີ່ແບ່ງປັນເພື່ອສຳຮອງຂໍ້ມູນ."

msgid ""
"This option specifies the group that the backup directories will belong to. "
"Note%3A This will only change the group of additionally created dirs. The "
"backed-up files and directories will mirror the original permissions."
msgstr "ຕົວເລືອກນີ້ກຳນົດກຸ່ມທີ່ໂຟນເດີສຳຮອງຂໍ້ມູນຈະສັງກັດຢູ່. ໝາຍເຫດ%3A ສິ່ງນີ້ຈະປ່ຽນແປງສະເພາະກຸ່ມຂອງໂຟນເດີທີ່ຖືກສ້າງຂຶ້ນເພີ່ມເຕີມເທົ່ານັ້ນ. ໄຟລ໌ ແລະ ໂຟນເດີທີ່ຖືກສຳຮອງຈະຍັງຄົງຮັກສາສິດການເຂົ້າເຖິງເດີມໄວ້."

msgid "Updated job."
msgstr "ອັບເດດວຽກແລ້ວ."

msgid "n/a"
msgstr "ບໍ່ມີຂໍ້ມູນ"
